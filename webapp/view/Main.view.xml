<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:table="sap.ui.table" controllerName="com.sap.validatecsv.controller.Main">

    <VBox id="_IDDescBox" class="sapUiMediumMargin">

        <!-- Upload Section -->
        <Panel id="_IDGenPanel" headerText="CSV File Validator and UTF-8 Compliance Tool" class="sapUiResponsiveMargin">
            <content>
                <VBox id="_IDGenVBox1">
                    <Text text="Upload your CSV files to automatically detect and resolve character encoding issues. This tool validates files for SuccessFactors Integration Center import requirements, including UTF-8 compliance, proper delimiters, unique headers, and field length limits. Get instant validation results with suggested corrections to ensure your files are ready for seamless processing."/>

                    <UploadCollection id="uploadCollection" maximumFilenameLength="55" maximumFileSize="10" multiple="false" instantUpload="false" sameFilenameAllowed="false" uploadEnabled="true" fileType="csv" noDataDescription="Drop files or use the &quot;Add&quot; button to keep files ready for upload" change="onFileChange" filenameLengthExceed="onFilenameLengthExceed" fileSizeExceed="onFileSizeExceed" typeMissmatch="onTypeMissmatch" mode="SingleSelect"/>

                    <Button id="_IDGenButton" text="Validate File" press="onValidateFile" type="Emphasized" tooltip="Perform UTF-8 validation" enabled="{= ${/uploadedFile} !== null}" class="sapUiTinyMarginTop"/>
                </VBox>
            </content>
        </Panel>

        <!-- Validation Results Section -->
        <Panel id="_IDGenPanel1" headerText="Validation Results" class="sapUiResponsiveMargin" visible="{= ${/validationResults/isValid} !== null}" expandable="true" expanded="false">
            <content>
                <VBox id="_IDGenVBox2">
                    <!-- Status -->
                    <MessageStrip id="_IDGenMessageStrip" text="{= ${/validationResults/isValid} ? 'File is valid and SuccessFactors compliant' : 'File contains validation issues - see details below'}" type="{= ${/validationResults/isValid} ? 'Success' : 'Error'}" class=""/>

                    <!-- File Info -->
                    <VBox id="_IDGenVBox3" class="sapUiTinyMarginTop">
                        <Label id="_IDGenLabel" text="Detected Encoding: {/validationResults/encoding}" class=""/>
                        <Label id="_IDGenLabel1" text="Total Rows: {/validationResults/totalRows}" class=""/>
                        <Label id="_IDGenLabel8" text="Data Rows: {/validationResults/stats/dataRows}" class=""/>
                        <Label id="_IDGenLabel10" text="Max Field Length: {/validationResults/stats/maxFieldLength} characters" class=""/>
                        <Label id="_IDGenLabel9" text="Total Errors: {/validationResults/errors/length}" class="" visible="{= ${/validationResults/errors/length} > 0}"/>
                        <Label id="_IDGenLabel2" text="Rows with Issues: {/validationResults/invalidRowsArray/length}" class="" visible="{= ${/validationResults/invalidRowsArray/length} > 0}"/>
                        <Label id="_IDGenLabel11" text="Warnings: {/validationResults/warnings/length}" class="" visible="{= ${/validationResults/warnings/length} > 0}"/>
                    </VBox>

                    <!-- Display All Errors (Collapsible) -->
                    <Panel id="_IDGenPanel4" 
                           headerText="Validation Errors ({/validationResults/errors/length})" 
                           class="sapUiTinyMarginTop" 
                           visible="{= ${/validationResults/errors/length} > 0}"
                           expandable="true"
                           expanded="false">
                        <content>
                            <List id="errorsList" items="{/validationResults/errors}">
                                <StandardListItem id="_IDGenStandardListItem" title="{}" type="Inactive"/>
                            </List>
                        </content>
                    </Panel>

                    <!-- Display All Warnings (Collapsible) -->
                    <Panel id="_IDGenPanel6" 
                           headerText="Warnings ({/validationResults/warnings/length})" 
                           class="sapUiTinyMarginTop" 
                           visible="{= ${/validationResults/warnings/length} > 0}"
                           expandable="true"
                           expanded="false">
                        <content>
                            <List id="warningsList" items="{/validationResults/warnings}">
                                <StandardListItem id="_IDGenStandardListItem2" title="{}" type="Inactive"/>
                            </List>
                        </content>
                    </Panel>
                </VBox>
            </content>
        </Panel>

        <!-- Invalid Rows Table -->
        <Panel id="_IDGenPanel2" headerText="Rows Requiring Correction" class="sapUiResponsiveMargin" visible="{= ${/validationResults/invalidRowsArray/length} > 0}">
            <content>
                <table:Table id="invalidRowsTable" rows="{/validationResults/invalidRowsArray}" selectionMode="None" visibleRowCount="10" enableSelectAll="false">
                    <table:columns>
                        <table:Column id="_IDGenColumn1" width="100px">
                            <Label id="_IDGenLabel3" text="Row Number"/>
                            <table:template>
                                <Text id="_IDGenText" text="{rowNumber}"/>
                            </table:template>
                        </table:Column>

                        <table:Column id="_IDGenColumn2" width="200px">
                            <Label id="_IDGenLabel4" text="Issue Type"/>
                            <table:template>
                                <Text id="_IDGenText1" text="{issueType}" wrapping="true"/>
                            </table:template>
                        </table:Column>

                        <table:Column id="_IDGenColumn3">
                            <Label id="_IDGenLabel5" text="Original Content"/>
                            <table:template>
                                <Text id="_IDGenText2" text="{originalContent}" wrapping="true" maxLines="3"/>
                            </table:template>
                        </table:Column>

                        <table:Column id="_IDGenColumn4">
                            <Label id="_IDGenLabel6" text="Suggested Fix"/>
                            <table:template>
                                <Text id="_IDGenText3" text="{suggestedFix}" wrapping="true" maxLines="3"/>
                            </table:template>
                        </table:Column>
                    </table:columns>
                </table:Table>
            </content>
        </Panel>

        <!-- CSV Preview -->
        <Panel id="_IDGenPanel3" headerText="CSV Preview (First 10 rows)" class="sapUiResponsiveMargin" visible="{= ${/csvData/length} > 0}" expandable="true" expanded="false">
            <content>
                <table:Table id="csvPreviewTable" rows="{/csvData}" selectionMode="None" visibleRowCount="10" enableSelectAll="false">
                </table:Table>
            </content>
        </Panel>

        <!-- Action Buttons -->
        <HBox id="_IDGenHBox" class="sapUiMediumMarginTop" visible="{= ${/validationResults/isValid} !== null}">
            <Button id="_IDGenButton1" text="Download Corrected File" press="onDownloadCorrected" type="Accept" visible="{= ${/validationResults/invalidRowsArray/length} > 0}" tooltip="Download file with all corrections applied" class="sapUiTinyMarginEnd"/>
            <Button id="_IDGenButton2" text="Clear Results" press="onClearResults" type="Neutral" tooltip="Clear the file selection and all results"/>
        </HBox>
    </VBox>
</mvc:View>